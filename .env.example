# ==============================================================================
# Environment Configuration Example
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# 1. GitHub Configuration
# Personal Access Token (PAT) with 'repo' scope to post review comments.
GITHUB_TOKEN=your_github_pat_here


# 2. Database Configuration
# PostgreSQL connection string.
# - Local development fallback: postgresql://postgres:postgres@localhost:5432/pr_review_db
# - Docker Compose environment: postgresql://postgres:postgres@db:5432/pr_review_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pr_review_db

# 3. Large Language Model (Ollama) Configuration
# URL of your local Ollama instance hosting qwen2.5-coder:7b and nomic-embed-text.
# - Local host: http://localhost:11434
# - Docker Compose (Windows host access): http://host.docker.internal:11434
# - Docker Compose (macOS/Linux host access): http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434

# 4. Vector Database (Qdrant) Configuration
# URL of your Qdrant instance.
# - Local host: http://localhost:6333
# - Docker Compose environment: http://qdrant:6333
QDRANT_URL=http://localhost:6333

# 5. Review Agent Safety Configurations
# Set to 'true' to run agent actions in simulation mode without posting comments.
DRY_RUN=false

# 6. Analytics Dashboard Configuration
# FastAPI server base URL queried by the Streamlit dashboard app.
API_URL=http://localhost:8000
